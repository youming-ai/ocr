{
  "name": "parsify-dev",
  "version": "2.0.0",
  "private": true,
  "description": "On-device OCR powered by PaddleOCR PP-OCRv6. Extract text from images and PDFs — source files never leave your browser.",
  "homepage": "https://parsify.dev",
  "repository": "https://github.com/youming-ai/parsify.dev",
  "bugs": "https://github.com/youming-ai/parsify.dev/issues",
  "keywords": [
    "ocr",
    "text-recognition",
    "paddleocr",
    "on-device",
    "privacy",
    "browser",
    "wasm",
    "pdf",
    "ai-cleanup",
    "image-to-text"
  ],
  "author": "Youming <ikashue@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun src/dev-server.ts & vite",
    "dev:api": "bun src/dev-server.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun src/prod-server.ts",
    "deploy": "bun run build && wrangler deploy",
    "lint": "biome check ./src",
    "lint:fix": "biome check --fix ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf node_modules dist .output",
    "postinstall": "mkdir -p public/ort && cp node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.mjs node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.wasm public/ort/ && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router": "^1.170.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.30",
    "lucide-react": "^1.24.0",
    "onnxruntime-web": "^1.27.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@cloudflare/vite-plugin": "^1.45.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tanstack/router-plugin": "^1.168.20",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.10",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.5"
}
